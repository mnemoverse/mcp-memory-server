{
  "name": "@mnemoverse/mcp-memory-server",
  "version": "0.3.5",
  "description": "MCP server for Mnemoverse Memory API — persistent AI memory across Claude Code, Cursor, VS Code, and any MCP client",
  "type": "module",
  "bin": {
    "mcp-memory-server": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "generate:configs": "node scripts/generate-configs.mjs",
    "verify:configs": "node scripts/generate-configs.mjs --check",
    "install-hooks": "node scripts/install-hooks.mjs",
    "prebuild": "npm run generate:configs",
    "prepublishOnly": "npm run build",
    "mcpb:validate": "npx -y @anthropic-ai/mcpb@2 validate .",
    "mcpb:pack": "npm run build && npx -y @anthropic-ai/mcpb@2 pack . dist-mcpb/mnemoverse-memory.mcpb"
  },
  "mcpName": "io.github.mnemoverse/mcp-memory-server",
  "keywords": [
    "mcp",
    "memory",
    "ai",
    "ai-agent",
    "claude",
    "cursor",
    "vscode",
    "chatgpt",
    "mnemoverse",
    "persistent-memory",
    "shared-memory",
    "cross-tool",
    "model-context-protocol"
  ],
  "author": "Mnemoverse <hello@mnemoverse.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mnemoverse/mcp-memory-server"
  },
  "homepage": "https://mnemoverse.com/docs/api/mcp-server",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^22.15.3"
  },
  "engines": {
    "node": ">=18"
  }
}
